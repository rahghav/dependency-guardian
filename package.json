{
  "name": "vulnguard",
  "version": "0.1.0",
  "description": "Multi-language dependency security scanner and health monitor",
  "main": "dist/index.js",
  "bin": {
    "vulnguard": "dist/cli.js",
    "vg": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "security",
    "dependencies",
    "vulnerabilities",
    "cve",
    "scanner",
    "cli",
    "devtools",
    "npm",
    "maven",
    "gradle",
    "python"
  ],
  "author": "Raghav",
  "license": "Apache-2.0",
  "repository": {
