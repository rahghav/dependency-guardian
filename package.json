    "url": "git+https://github.com/racha24/dependency-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/racha24/dependency-guardian/issues"
  },
  "homepage": "https://github.com/racha24/dependency-guardian#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ora": "^5.4.1",
    "axios": "^1.6.2",
    "cli-table3": "^0.6.3",
    "fast-xml-parser": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  }
